<Window x:Class="GearGauge.UI.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:GearGauge.UI.Converters"
        xmlns:vm="clr-namespace:GearGauge.UI.ViewModels"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        Focusable="False">
    <Window.Resources>
        <conv:StringToBrushConverter x:Key="BrushConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Border x:Name="OverlayBackground"
            CornerRadius="16"
            Padding="12,8"
            Background="Transparent">
        <ItemsControl x:Name="MetricsItems"
                      FontSize="{Binding FontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                      ItemsSource="{Binding Metrics}">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:OverlayMetricViewModel}">
                    <StackPanel Orientation="Horizontal"
                                Margin="6,2"
                                Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}">
                        <TextBlock x:Name="IconText"
                                   FontFamily="Segoe Fluent Icons"
                                   Margin="0,0,4,0"
                                   VerticalAlignment="Center"
                                   Text="{Binding IconGlyph}"
                                   Foreground="{Binding DisplayColor, Converter={StaticResource BrushConverter}}"
                                   Visibility="{Binding ShowIcon, Converter={StaticResource BoolToVis}}" />
                        <TextBlock x:Name="LabelText"
                                   FontWeight="SemiBold"
                                   Margin="0,0,6,0"
                                   VerticalAlignment="Center"
                                   Text="{Binding Label}"
                                   Foreground="{Binding DisplayColor, Converter={StaticResource BrushConverter}}"
                                   Visibility="{Binding ShowLabel, Converter={StaticResource BoolToVis}}" />
                        <TextBlock x:Name="ValueText"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center"
                                   Text="{Binding Value}"
                                   Foreground="{Binding DisplayColor, Converter={StaticResource BrushConverter}}" />
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Border>
</Window>
